{
  "name": "openclaw-plugin-hermes",
  "version": "1.0.0",
  "description": "Hermes gateway integration for OpenClaw",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shadowkun/openclaw-plugin-hermes.git"
  },
  "homepage": "https://github.com/shadowkun/openclaw-plugin-hermes#readme",
  "bugs": {
    "url": "https://github.com/shadowkun/openclaw-plugin-hermes/issues"
  },
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "openclaw.plugin.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "hermes",
    "ai-gateway",
    "chat-completions"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test && npm run build",
    "pack": "npm run build && npm pack"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
