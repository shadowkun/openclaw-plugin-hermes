# Hermes configuration example
# Copy this to ~/.hermes/.env and adjust values as needed

# Required: Enable the API server
API_SERVER_ENABLED=true

# Required: Set a secure API key
# This value must match the apiKey in your OpenClaw plugin config
API_SERVER_KEY=your-secure-api-key-here

# Server binding
# Use 127.0.0.1 for local-only access (recommended)
# Use 0.0.0.0 only if exposing externally, and you MUST use a secure API key
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8642

# Optional: Model configuration (depends on your Hermes setup)
# MODEL_NAME=default

# Optional: Logging
# LOG_LEVEL=info